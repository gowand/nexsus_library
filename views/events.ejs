<%- include("partials/header",{title:"Etkinlikler"}) %><main class="lib-page"><%- include("partials/library-nav",{lib}) %><h1>Etkinlikler</h1><form class="search"><input name="q" value="<%= q %>" placeholder="Etkinlik ara"><input name="category" value="<%= category %>" placeholder="Kategori"><button>Filtrele</button></form><div class="cards"><% events.forEach(e=>{ %><article class="card"><div class="poster"><% if(e.poster_url){ %><img src="<%= e.poster_url %>"><% } else { %>📅<% } %></div><span class="pill"><%= e.category %></span><h3><%= e.title %></h3><p><%= e.event_date %> • <%= e.event_time %></p><form class="mini-form" method="post" action="/<%= lib.slug %>/events/<%= e.id %>/apply"><input name="first_name" placeholder="Ad" required><input name="last_name" placeholder="Soyad" required><input name="phone" placeholder="05XXXXXXXXX" required><input name="age" type="number" placeholder="Yaş" required><button>Başvur</button></form></article><% }) %></div></main><%- include("partials/footer") %>
