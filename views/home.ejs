<%- include("partials/header",{title:"Ana Sayfa"}) %><%- include("partials/nav") %><main class="container"><section class="hero"><div><span class="pill">Enterprise V4</span><h1>Dijital Kütüphane Etkinlik ve Arşiv Platformu</h1><p>1000+ kütüphane için PostgreSQL destekli modern sistem.</p><form class="search"><input name="q" placeholder="Kütüphane ara"><button>Ara</button></form></div><div class="hero-stat"><b><%= stats.libraries %></b><span>Kütüphane</span><small><%= stats.events %> etkinlik • <%= stats.games %> oyun</small></div></section><h2>Onaylı Kütüphaneler</h2><div class="cards"><% libraries.forEach(l=>{ %><a class="card" href="/<%= l.slug %>"><div class="banner-mini"></div><span class="pill"><%= l.rank_name %> • <%= l.score %></span><h3><%= l.name %></h3><p><%= l.address %></p></a><% }) %></div></main><%- include("partials/footer") %>
