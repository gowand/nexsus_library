<%- include("partials/header",{title:"Ayarlar"}) %><%- include("partials/nav") %><main class="dash"><%- include("partials/panel-sidebar") %><section><form class="box wide" method="post"><h1>Genel Ayarlar</h1><textarea name="about"><%= lib.about %></textarea><input name="working_hours" value="<%= lib.working_hours %>" placeholder="Çalışma saatleri"><input name="phone" value="<%= lib.phone %>" placeholder="Telefon"><input name="address" value="<%= lib.address %>" placeholder="Adres"><label>Logo X <input type="range" name="logo_pos_x" min="0" max="100" value="<%= lib.logo_pos_x %>"></label><label>Logo Y <input type="range" name="logo_pos_y" min="0" max="100" value="<%= lib.logo_pos_y %>"></label><label>Logo Zoom <input type="range" name="logo_zoom" min="1" max="2" step="0.05" value="<%= lib.logo_zoom %>"></label><label>Banner X <input type="range" name="banner_pos_x" min="0" max="100" value="<%= lib.banner_pos_x %>"></label><label>Banner Y <input type="range" name="banner_pos_y" min="0" max="100" value="<%= lib.banner_pos_y %>"></label><button>Kaydet</button></form></section></main><%- include("partials/footer") %>
