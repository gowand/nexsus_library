<%- include("partials/header",{title:"Arşiv"}) %><%- include("partials/nav") %><main class="dash"><%- include("partials/panel-sidebar") %><section><h1>Arşiv</h1><div class="list"><% events.forEach(e=>{ %><div class="row"><b><%= e.title %></b><form method="post" action="/panel/archive/<%= e.id %>/photo" enctype="multipart/form-data"><input type="file" name="archive_photo" accept="image/*" required><input name="caption" placeholder="Açıklama"><button>Fotoğraf Ekle</button></form></div><% }) %></div><h2>Fotoğraflar</h2><div class="cards"><% photos.forEach(p=>{ %><div class="card"><div class="poster"><img src="<%= p.photo_url %>"></div><p><%= p.caption %></p><form method="post" action="/panel/archive/photo/<%= p.id %>/delete"><button class="danger">Sil</button></form></div><% }) %></div></section></main><%- include("partials/footer") %>
