<%- include("partials/header",{title:lib.name}) %><main class="lib-page"><%- include("partials/library-nav",{lib}) %><% if(announcements.length){ %><div class="ann">📢 <%= announcements[0].title %> — <%= announcements[0].body %></div><% } %><section class="lib-banner" style="background-image:linear-gradient(135deg,rgba(9,42,30,.1),rgba(217,168,73,.08)),url('<%= lib.banner_url || "https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=1600&auto=format&fit=crop" %>');background-position:<%= lib.banner_pos_x %>% <%= lib.banner_pos_y %>%"><div class="badge">🏆 <%= lib.rank_name %></div></section><section class="info"><span class="pill"><%= lib.score %> Puan</span><h1><%= lib.name %></h1><p><%= lib.about %></p><a class="btn" href="/<%= lib.slug %>/events">Etkinlik Başvurusu</a><a class="btn ghost" href="/<%= lib.slug %>/games">Kütüphanemizi Keşfet</a></section><div class="three"><div><h3>Hakkında</h3><p><%= lib.about %></p></div><div><h3>Çalışma Saatleri</h3><p><%= lib.working_hours %><br><%= lib.phone %></p></div><div><h3>Rakamlarla Biz</h3><p><%= events.length %> etkinlik<br><%= games.length %> oyun<br><%= lib.score %> puan</p></div></div></main><%- include("partials/footer") %>
