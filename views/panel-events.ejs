<%- include("partials/header",{title:"Etkinlikler"}) %><%- include("partials/nav") %><main class="dash"><%- include("partials/panel-sidebar") %><section><h1>Etkinlikler</h1><form class="box wide" method="post" enctype="multipart/form-data"><input name="title" placeholder="Etkinlik adı" required><textarea name="description" placeholder="Açıklama"></textarea><input name="category" placeholder="Kategori"><input type="date" name="event_date" required><input name="event_time" placeholder="15:00"><input name="place" placeholder="Yer"><input type="number" name="min_age" placeholder="Min yaş"><input type="number" name="max_age" placeholder="Max yaş"><input type="number" name="capacity" placeholder="Kontenjan"><input type="file" name="poster" accept="image/*"><button>Etkinlik Ekle</button></form><div class="list"><% events.forEach(e=>{ %><div class="row"><b><%= e.title %></b><span><%= e.event_date %> • <%= e.application_count %> başvuru</span><form method="post" action="/panel/events/<%= e.id %>/archive"><button>Arşivle</button></form><form method="post" action="/panel/events/<%= e.id %>/delete"><button class="danger">Sil</button></form></div><% }) %></div></section></main><%- include("partials/footer") %>
