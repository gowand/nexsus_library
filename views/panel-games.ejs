<%- include("partials/header",{title:"Oyunlar"}) %><%- include("partials/nav") %><main class="dash"><%- include("partials/panel-sidebar") %><section><h1>Oyunlar</h1><form class="box wide" method="post"><input name="name" placeholder="Oyun adı" required><input name="category" placeholder="Kategori"><textarea name="description" placeholder="Açıklama"></textarea><textarea name="how_to_play" placeholder="Nasıl oynanır"></textarea><input name="age_range" placeholder="Yaş aralığı"><input name="players" placeholder="Oyuncu sayısı"><input name="pieces" placeholder="Parça sayısı"><input name="shelf_code" placeholder="Raf kodu"><label><input type="checkbox" name="available" checked> Müsait</label><button>Oyun Ekle</button></form><div class="list"><% games.forEach(g=>{ %><div class="row"><b><%= g.name %></b><span><%= g.shelf_code %></span><form method="post" action="/panel/games/<%= g.id %>/delete"><button class="danger">Sil</button></form></div><% }) %></div></section></main><%- include("partials/footer") %>
